{
  "manifest_version": 3,
  "name": "PT → Garmin FIT",
  "version": "1.0.0",
  "description": "Extract PT Wired exercises and generate Garmin .FIT workout files",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://rspt.mobile.ptwired.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "PT → Garmin FIT"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
